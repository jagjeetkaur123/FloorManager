generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]

  @@map("users")
}

model Job {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  company     String
  location    String
  salary      Float?
  type        JobType   @default(FULL_TIME)
  status      JobStatus @default(OPEN)
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("jobs")
}

enum Role {
  USER
  ADMIN
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  CASUAL
}

enum JobStatus {
  OPEN
  CLOSED
  DRAFT
}
